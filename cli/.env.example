# IC network URL — use http://localhost:8080 for local dfx, https://ic0.app for mainnet
IC_NETWORK=http://localhost:8080

# Canister ID — auto-detected from .dfx/local/canister_ids.json if omitted
# IC_CANISTER_ID=uxrrr-q7777-77774-qaaaq-cai

# Path to a secp256k1 identity PEM file (dfx identity export <name> > identity.pem)
# IC_IDENTITY_FILE=~/.config/dfx/identity/default/identity.pem

# Set to true on mainnet to skip fetchRootKey()
IC_PRODUCTION=false
